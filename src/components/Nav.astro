---
const navItems = [
  {
    id: "hero",
    label: "Home",
    icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
  },
  {
    id: "education",
    label: "Education",
    icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>`,
  },
  {
    id: "experience",
    label: "Experience",
    icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/></svg>`,
  },
  {
    id: "projects",
    label: "Projects",
    icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>`,
  },
  {
    id: "hire",
    label: "Hire Me",
    icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>`,
  },
];
---

<aside
  id="nav-panel"
  class="w-64 flex-shrink-0 flex flex-col bg-[#09091a] border-r border-white/[0.07] fixed inset-y-0 left-0 z-50 -translate-x-full transition-transform duration-300 ease-in-out md:static md:translate-x-0 md:transition-none"
>
  <!-- Mobile close header -->
  <div class="md:hidden flex items-center justify-between px-4 py-3 border-b border-white/[0.07]">
    <span class="text-xs text-slate-500 uppercase tracking-widest font-semibold">Menu</span>
    <button
      id="nav-close"
      aria-label="Close menu"
      class="p-1.5 rounded-lg hover:bg-white/[0.08] text-slate-400 hover:text-white transition-colors"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <!-- Profile -->
  <div class="p-5 pb-4">
    <div class="flex items-center gap-3 mb-4">
      <!-- Avatar: shows photo if available, falls back to initials -->
      <div class="w-10 h-10 rounded-lg overflow-hidden flex-shrink-0 relative bg-white/[0.08]">
        <img
          src="/images/tk-square.jpg"
          alt="Kristoff Urcia"
          class="w-full h-full object-cover"
          onerror="this.style.display='none';this.nextElementSibling.removeAttribute('hidden')"
        />
        <div
          hidden
          class="absolute inset-0 flex items-center justify-center text-white text-xs font-bold font-mono"
        >
          KU
        </div>
      </div>
      <div class="min-w-0">
        <p class="text-sm font-semibold text-white truncate">Kristoff Urcia</p>
        <p class="text-xs text-slate-500 truncate">Software Engineer</p>
      </div>
    </div>
    <div class="flex items-center gap-2 bg-emerald-500/[0.08] border border-emerald-500/20 rounded-full px-3 py-1.5 w-fit">
      <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 pulse-dot flex-shrink-0"></span>
      <span class="text-xs text-emerald-400 font-medium">Open to work</span>
    </div>
  </div>

  <div class="h-px bg-white/[0.06] mx-4"></div>

  <!-- Nav items -->
  <nav class="flex-1 p-3 pt-3 flex flex-col gap-0.5" role="navigation" aria-label="Main navigation">
    {navItems.map(({ id, label, icon }, i) => (
      <button
        data-nav-item={id}
        aria-current={i === 0 ? "page" : "false"}
        class="flex items-center gap-3 w-full px-3 py-2.5 rounded-lg text-left text-sm font-medium text-slate-500 hover:text-slate-200 hover:bg-white/[0.05] transition-all duration-150 border-l-2 border-transparent aria-[current=page]:text-white aria-[current=page]:bg-white/[0.07] aria-[current=page]:border-white/30 cursor-pointer"
      >
        <span class="flex-shrink-0" set:html={icon} />
        {label}
      </button>
    ))}
  </nav>

  <!-- Social links -->
  <div class="p-4 border-t border-white/[0.06]">
    <p class="text-xs text-slate-700 uppercase tracking-widest font-semibold mb-3">Connect</p>
    <div class="flex items-center gap-2">
      <a
        href="https://github.com/toffku"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub"
        class="w-8 h-8 rounded-lg bg-white/[0.05] hover:bg-white/[0.10] border border-white/[0.08] flex items-center justify-center text-slate-500 hover:text-white transition-all duration-150"
      >
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
        </svg>
      </a>
      <a
        href="https://linkedin.com/in/kristoff-urcia"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn"
        class="w-8 h-8 rounded-lg bg-white/[0.05] hover:bg-white/[0.10] border border-white/[0.08] flex items-center justify-center text-slate-500 hover:text-white transition-all duration-150"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
      <a
        href="mailto:kristoffurcia.ku@gmail.com"
        aria-label="Email"
        class="w-8 h-8 rounded-lg bg-white/[0.05] hover:bg-white/[0.10] border border-white/[0.08] flex items-center justify-center text-slate-500 hover:text-white transition-all duration-150"
      >
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect width="20" height="16" x="2" y="4" rx="2"/>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
        </svg>
      </a>
    </div>
  </div>
</aside>
