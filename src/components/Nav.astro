---
import Image from "astro/components/Image.astro";
import { site } from "@/data/site";
import { navItems } from "@/data/navigation";
import { socials } from "@/data/socials";
---

<aside
  id="nav-panel"
  class="w-64 flex-shrink-0 flex flex-col bg-[#111] border-r border-white/[0.07] fixed inset-y-0 left-0 z-50 -translate-x-full transition-transform duration-300 ease-in-out md:static md:translate-x-0 md:transition-none"
>
  <!-- Mobile close header -->
  <div class="md:hidden flex items-center justify-between px-4 py-3 border-b border-white/[0.07]">
    <span class="text-xs text-gray-500 uppercase tracking-widest font-semibold">Menu</span>
    <button
      id="nav-close"
      aria-label="Close menu"
      class="p-1.5 rounded-lg hover:bg-white/[0.08] text-gray-400 hover:text-white transition-colors"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <!-- Profile -->
  <div class="p-5 pb-4">
    <div class="flex items-center gap-3 mb-4">
      <div class="w-10 h-10 rounded-lg overflow-hidden flex-shrink-0 relative bg-white/[0.08]">
        <Image
          src={site.avatar}
          alt={`${site.name} avatar`}
          width={40}
          height={40}
          class="object-cover w-full h-full"
          loading="eager"
        />
      </div>
      <div class="min-w-0">
        <p class="text-sm font-semibold text-white truncate">{site.name} ({site.handle})</p>
        <p class="text-xs text-gray-300 truncate">{site.title}</p>
      </div>
    </div>
    {site.availability.available && (
      <div class="flex items-center gap-2 bg-emerald-500/[0.08] border border-emerald-500/20 rounded-full px-3 py-1.5 w-fit">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 pulse-dot flex-shrink-0"></span>
        <span class="text-xs text-emerald-400 font-medium">{site.availability.label}</span>
      </div>
    )}
  </div>

  <div class="h-px bg-white/[0.06] mx-4"></div>

  <!-- Nav items -->
  <nav class="flex-1 p-3 pt-3 flex flex-col gap-0.5" role="navigation" aria-label="Main navigation">
    {navItems.map(({ id, label, icon, activeClasses }, i) => (
      <button
        data-nav-item={id}
        aria-current={i === 0 ? "page" : "false"}
        class={`flex items-center gap-3 w-full px-3 py-2.5 rounded-lg text-left text-sm font-medium text-gray-400 hover:text-gray-200 hover:bg-white/[0.05] transition-all duration-150 border-l-2 border-transparent cursor-pointer ${activeClasses}`}
      >
        <span class="flex-shrink-0" set:html={icon} />
        {label}
      </button>
    ))}
  </nav>

  <!-- Social links -->
  <div class="p-4 border-t border-white/[0.06]">
    <p class="text-xs text-gray-700 uppercase tracking-widest font-semibold mb-3">Connect</p>
    <div class="flex items-center gap-2">
      {socials.map((social) => (
        <a
          href={social.href}
          target={social.href.startsWith("mailto") ? undefined : "_blank"}
          rel={social.href.startsWith("mailto") ? undefined : "noopener noreferrer"}
          aria-label={social.label}
          class="w-8 h-8 rounded-lg bg-white/[0.05] hover:bg-white/[0.10] border border-white/[0.08] flex items-center justify-center text-gray-500 hover:text-white transition-all duration-150"
        >
          <span set:html={social.icon} />
        </a>
      ))}
    </div>
  </div>
</aside>
