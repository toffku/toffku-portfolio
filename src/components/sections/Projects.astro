---
const projects = [
  {
    name: "HPE Parts Validation",
    description:
      "Mobile application for validating and tracking hardware components. Built for Hewlett Packard Enterprise to streamline parts verification workflows across teams.",
    tags: ["TypeScript", "React Native", "SQL"],
    github: null,
    featured: true,
  },
  {
    name: "UCycle",
    description:
      "Cycling route planner mobile application developed as my Honours Project. Integrates route planning features to help cyclists discover and navigate routes.",
    tags: ["TypeScript", "React Native", "Expo"],
    github: "https://github.com/toffku/UCycle",
    featured: true,
  },
  {
    name: "simple-pm",
    description:
      "Lightweight project management application with a clean interface for tracking tasks and organising work. Built with a Node.js backend and TypeScript throughout.",
    tags: ["TypeScript", "Node.js"],
    github: "https://github.com/toffku/simple-pm",
    featured: false,
  },
  {
    name: "Onwards to the Past",
    description:
      "Web-based top-down platformer game — a JavaScript rewrite of a game originally created with GML. Runs entirely in the browser with no dependencies.",
    tags: ["JavaScript", "Canvas API", "Game Dev"],
    github: "https://github.com/toffku/onwards-to-the-past-js",
    featured: false,
  },
];
---

<div class="min-h-full px-8 py-12 md:px-14 md:py-16 overflow-y-auto">
  <div class="max-w-3xl">
    <div class="mb-8">
      <p class="font-mono text-xs text-white/25 mb-2">04 / Projects</p>
      <h2 class="text-3xl font-bold text-white mb-2">Featured Work</h2>
      <p class="text-slate-500 text-sm">A selection of engineering projects and open-source work.</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
      {projects.map((project) => (
        <div class="group relative bg-white/[0.03] hover:bg-white/[0.05] border border-white/[0.08] hover:border-white/[0.18] rounded-xl p-5 transition-all duration-200 flex flex-col">
          {project.featured && (
            <div class="absolute top-4 right-4">
              <span class="text-[10px] font-semibold font-mono text-white/20 uppercase tracking-widest">Featured</span>
            </div>
          )}

          <!-- Icon -->
          <div class="w-9 h-9 rounded-lg bg-white/[0.05] border border-white/[0.08] flex items-center justify-center mb-4 text-slate-400">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
            </svg>
          </div>

          <h3 class="text-sm font-semibold text-white mb-2 pr-14">{project.name}</h3>
          <p class="text-xs text-slate-500 leading-relaxed mb-4 flex-1">{project.description}</p>

          <div class="flex flex-wrap gap-1.5 mb-4">
            {project.tags.map((tag) => (
              <span class="text-xs font-mono px-2 py-0.5 rounded border bg-white/[0.04] text-slate-500 border-white/[0.08]">
                {tag}
              </span>
            ))}
          </div>

          <div class="flex items-center gap-3 pt-3 border-t border-white/[0.06]">
            {project.github ? (
              <a
                href={project.github}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-1.5 text-xs text-slate-500 hover:text-white transition-colors font-medium"
              >
                <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
                </svg>
                View Source
              </a>
            ) : (
              <span class="flex items-center gap-1.5 text-xs text-slate-600 font-medium">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
                Private
              </span>
            )}
          </div>
        </div>
      ))}
    </div>

    <!-- GitHub CTA -->
    <div class="mt-6 flex items-center gap-3 bg-white/[0.02] border border-white/[0.07] rounded-xl px-5 py-4">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" class="text-slate-600 flex-shrink-0">
        <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
      </svg>
      <p class="text-sm text-slate-600 flex-1">More projects and contributions on GitHub.</p>
      <a
        href="https://github.com/toffku"
        target="_blank"
        rel="noopener noreferrer"
        class="text-xs text-slate-400 hover:text-white font-medium flex items-center gap-1 transition-colors whitespace-nowrap"
      >
        @toffku
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M7 17L17 7M7 7h10v10"/>
        </svg>
      </a>
    </div>
  </div>
</div>
