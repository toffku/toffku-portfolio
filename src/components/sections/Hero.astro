---
---

<div class="min-h-full flex items-center px-8 py-12 md:px-14 md:py-16">
  <div class="max-w-2xl w-full">
    <!-- Terminal prefix -->
    <p class="font-mono text-xs text-white/25 mb-5 flex items-center gap-2">
      <span>~/portfolio</span>
      <span class="text-white/15">$</span>
      <span>whoami</span>
    </p>

    <!-- Name -->
    <h1 class="text-5xl md:text-6xl font-extrabold tracking-tight mb-3 leading-none">
      <span class="text-white">Kristoff</span>
      <br />
      <span class="text-white/60">Urcia</span>
    </h1>

    <!-- Title -->
    <p class="text-slate-400 text-lg font-medium mb-6 flex items-center gap-3">
      <span class="w-8 h-px bg-white/20"></span>
      Software Engineer
    </p>

    <!-- Bio -->
    <p class="text-slate-400 text-base leading-relaxed mb-8 max-w-lg">
      Glasgow-based engineer with hands-on experience building internal and
      customer-facing applications. Focused on TypeScript, React Native, and
      writing clean, maintainable code that solves real problems.
    </p>

    <!-- CTA buttons -->
    <div class="flex flex-wrap gap-3 mb-10">
      <button
        data-nav-item="projects"
        class="inline-flex items-center gap-2 bg-white hover:bg-slate-100 text-zinc-900 text-sm font-semibold px-5 py-2.5 rounded-lg transition-all duration-150 hover:-translate-y-0.5"
      >
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
        </svg>
        View Projects
      </button>
      <button
        data-nav-item="hire"
        class="inline-flex items-center gap-2 bg-white/[0.07] hover:bg-white/[0.12] border border-white/[0.12] text-slate-200 text-sm font-semibold px-5 py-2.5 rounded-lg transition-all duration-150 hover:-translate-y-0.5"
      >
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
        </svg>
        Hire Me
      </button>
      <a
        href="https://github.com/toffku"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-white/[0.05] hover:bg-white/[0.09] border border-white/[0.08] text-slate-400 hover:text-slate-200 text-sm font-medium px-4 py-2.5 rounded-lg transition-all duration-150 hover:-translate-y-0.5"
      >
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
        </svg>
        GitHub
      </a>
      <a
        href="https://linkedin.com/in/kristoff-urcia"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-white/[0.05] hover:bg-white/[0.09] border border-white/[0.08] text-slate-400 hover:text-slate-200 text-sm font-medium px-4 py-2.5 rounded-lg transition-all duration-150 hover:-translate-y-0.5"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
        LinkedIn
      </a>
    </div>

    <!-- Stat chips -->
    <div class="flex flex-wrap gap-3">
      <div class="flex items-center gap-2 bg-white/[0.04] border border-white/[0.07] rounded-full px-3 py-1.5">
        <span class="w-1 h-1 rounded-full bg-white/30"></span>
        <span class="text-xs text-slate-400 font-mono">BSc Software Engineering</span>
      </div>
      <div class="flex items-center gap-2 bg-white/[0.04] border border-white/[0.07] rounded-full px-3 py-1.5">
        <span class="w-1 h-1 rounded-full bg-white/30"></span>
        <span class="text-xs text-slate-400 font-mono">1yr industry experience</span>
      </div>
      <div class="flex items-center gap-2 bg-white/[0.04] border border-white/[0.07] rounded-full px-3 py-1.5">
        <span class="w-1 h-1 rounded-full bg-white/30"></span>
        <span class="text-xs text-slate-400 font-mono">Glasgow, Scotland</span>
      </div>
    </div>
  </div>
</div>
