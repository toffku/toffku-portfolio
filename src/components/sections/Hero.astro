---
---

<div class="min-h-full flex items-center px-8 py-12 md:px-14 md:py-16">
  <div class="max-w-2xl w-full">
    <!-- Terminal prefix -->
    <p class="font-mono text-xs text-white/25 mb-5 flex items-center gap-2">
      <span>~/portfolio</span>
      <span class="text-white/15">$</span>
      <span>whoami</span>
    </p>

    <!-- Name -->
    <h1 class="text-5xl md:text-6xl font-extrabold mb-3 leading-none">
      <span class="text-white/80">Hi,</span>
      <br />
      <span class="text-white">I'm Kristoff.</span>
    </h1>

    <!-- Title -->
    <p class="text-gray-400 text-lg font-medium mb-6 flex items-center gap-3">
      <span class="w-8 h-px bg-white/20"></span>
      Software Engineer
    </p>

    <!-- Bio -->
    <p class="text-gray-400 text-base leading-relaxed mb-8 max-w-lg">
      Glasgow-based engineer with a passion for clean code, intuitive UI/UX, and learning new technologies.
    </p>

    <!-- CTA buttons -->
    <div class="flex flex-wrap gap-3 mb-10">

      <button
        data-nav-item="hire"
        class="inline-flex items-center gap-2 bg-emerald-600 hover:bg-emerald-500 border border-emerald-300 text-sm font-semibold px-5 py-2.5 rounded-lg transition-all duration-150 hover:-translate-y-0.5 cursor-pointer"
      >
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
        </svg>
        Hire Me
      </button>
    </div>

    <!-- Stat chips -->
    <div class="flex flex-wrap gap-3">
      <div class="flex items-center gap-2 bg-indigo-500/[0.08] border border-indigo-500/20 rounded-full px-3 py-1.5">
        <span class="w-1 h-1 rounded-full bg-indigo-400/60"></span>
        <span class="text-xs text-indigo-300/80 font-mono">BSc Software Engineering</span>
      </div>
      <div class="flex items-center gap-2 bg-amber-500/[0.08] border border-amber-500/20 rounded-full px-3 py-1.5">
        <span class="w-1 h-1 rounded-full bg-amber-400/60"></span>
        <span class="text-xs text-amber-300/80 font-mono">1+ YOE</span>
      </div>
      <div class="flex items-center gap-2 bg-sky-500/[0.08] border border-sky-500/20 rounded-full px-3 py-1.5">
        <span class="w-1 h-1 rounded-full bg-sky-400/60"></span>
        <span class="text-xs text-sky-300/80 font-mono">Glasgow, Scotland</span>
      </div>
    </div>
  </div>
</div>
