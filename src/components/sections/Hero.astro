---
import { site } from "@/data/site";

const firstName = site.name.split(" ")[0];
---

<div class="min-h-full flex items-center px-8 py-12 md:px-14 md:py-16">
  <div class="max-w-2xl w-full">
    <p class="font-mono text-xs text-white/25 mb-5 flex items-center gap-2">
      <span>~/portfolio</span>
      <span class="text-white/15">$</span>
      <span>whoami</span>
    </p>

    <h1 class="text-5xl md:text-6xl font-extrabold mb-3 leading-none">
      <span class="text-white/80">Hi,</span>
      <br />
      <span class="text-white">I'm {firstName}.</span>
    </h1>

    <p class="text-gray-400 text-lg font-medium mb-6 flex items-center gap-3">
      <span class="w-8 h-px bg-white/20"></span>
      {site.title}
    </p>

    <p class="text-gray-400 text-base leading-relaxed mb-8 max-w-lg">
      {site.bio}
    </p>

    <div class="flex flex-wrap gap-3 mb-10">
      <button
        data-nav-item="hire"
        class="inline-flex items-center gap-2 bg-emerald-600 hover:bg-emerald-500 border border-emerald-300 text-sm font-semibold px-5 py-2.5 rounded-lg transition-all duration-150 hover:-translate-y-0.5 cursor-pointer"
      >
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
        </svg>
        Hire Me
      </button>
    </div>

    <div class="flex flex-wrap gap-3">
      {site.stats.map((stat) => (
        <div class={`flex items-center gap-2 ${stat.color.bg} border ${stat.color.border} rounded-full px-3 py-1.5`}>
          <span class={`w-1 h-1 rounded-full ${stat.color.dot}`}></span>
          <span class={`text-xs ${stat.color.text} font-mono`}>{stat.label}</span>
        </div>
      ))}
    </div>
  </div>
</div>
